# Environment Configuration for EcoPredict
# Copy this file to .env and fill in your values

# ================================
# Application Settings
# ================================
APP_NAME=EcoPredict
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ================================
# API Configuration
# ================================
API_HOST=0.0.0.0
PORT=8000
API_WORKERS=4
MAX_WORKERS=4
RELOAD=false
PYTHONUNBUFFERED=1

# ================================
# Database Configuration
# ================================
# PostgreSQL (optional, comment out if using CSV)
DATABASE_URL=postgresql://ecopredict_user:password@localhost:5432/ecopredict
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# MongoDB (optional)
# MONGODB_URI=mongodb://localhost:27017/ecopredict

# ================================
# Cache Configuration
# ================================
# Redis (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# ================================
# Security
# ================================
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://ecopredict.com

# ================================
# External APIs
# ================================
# GBIF API settings (default: public API, no key required)
GBIF_API_BASE_URL=https://api.gbif.org/v1
GBIF_TIMEOUT=10

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/api.log

# ================================
# Monitoring
# ================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ================================
# Data Files
# ================================
DATA_FILE_PATH=/app/data/insect.csv

# ================================
# Frontend Configuration (React)
# ================================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# ================================
# Render Production Settings
# ================================
# Uncomment and set these when deploying to Render
# RENDER_SERVICE_NAME=ecopredict-api
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# Update CORS_ORIGINS to include your Render frontend URL

# ================================
# Passwords (Development Only)
# ================================
DB_PASSWORD=ecopredict_password
GRAFANA_PASSWORD=admin
